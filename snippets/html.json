{
  "custom element": {
    "prefix": "jj",
    "body": "<${1:elementName}>\n\t$0\n</${1}>",
    "description": "an element"
  },
  "custom element self closed": {
    "prefix": "jc",
    "body": "<${1:elementName} />",
    "description": "an element self closed"
  },
  "doctype": {
    "prefix": "doctype",
    "body": ["<!DOCTYPE>", "$1"],
    "description": "HTML - Defines the document type",
    "scope": "text.html"
  },
  "div": {
    "prefix": "div",
    "body": "<div>$1</div>",
    "description": "HTML - Defines the document type",
    "scope": "text.html"
  },
  "div 3 times": {
    "prefix": "div3",
    "body": [
      "<div>",
      "\t$1",
      "</div>\n<div>",
      "\t$1",
      "</div>\n<div>",
      "\t$1",
      "</div>"
    ],
    "description": "3 div element"
  },

  "ul > li": {
    "prefix": "ul",
    "body": [
      "<ul>",
      "\t<li>\n</li>",
      "</ul>"
    ],
    "description": "ul with li child"
  },
  "class attribute": {
    "prefix": "cl",
    "body": "class=\"$1\"$0",
    "description": "HTML class attribute",
    "scope": "text.html"
  }
}
