{
  "element": {
    "prefix": "jj",
    "body": "<$1>\n\t$0\n</${1}>",
    "description": "an element"
  },
  "element self closed": {
    "prefix": "jc",
    "body": "<$1 />",
    "description": "an element self closed"
  },
  "div": {
    "prefix": "div",
    "body": "<div>\n\t$1\n</div>",
    "description": "HTML - Defines the document type",
    "scope": "text.html"
  },
  "ul > li": {
    "prefix": "ul",
    "body": [
      "<ul>",
      "\t<li>\n\t\t$1\n\t</li>",
      "</ul>"
    ],
    "description": "ul with li child"
  },
  "class attribute": {
    "prefix": "cl",
    "body": "class=\"$1\"$0",
    "description": "HTML class attribute",
    "scope": "text.html"
  }
}
