{
  "handle events ": {
    "prefix": "handle-func",
    "body": [
      "const handle${1:func} = () => {",
      "\t$2",
      "}"
    ],
    "description": "handle events"
  },
  "Switch Statement": {
    "prefix": "switch-case",
    "body": [
      "switch (${1:key}) {",
      "\tcase ${2:value}:",
      "\t\t$0",
      "\t\tbreak;",
      "",
      "\tdefault:",
      "\t\tbreak;",
      "}"
    ],
    "description": "Switch Statement"
  },
  "arrow function ": {
    "prefix": "(",
    "body": "($1) => {$2}"
  },
  "Set Timeout Function": {
    "prefix": "set-timeout",
    "body": [
      "setTimeout(() => {",
      "\t$0",
      "}, ${1:timeout});"
    ],
    "description": "Set Timeout Function"
  },
  "Set Interval Function": {
    "prefix": "set-interval",
    "body": [
      "setInterval(() => {",
      "\t$0",
      "}, ${1:interval});"
    ],
    "description": "Set Interval Function"
  },
  "Generate Array": {
    "prefix": "array-from",
    "body": "Array.from({ length: ${1:5}})",
    "description": "Generate array"
  },
  "Import": {
    "prefix": "imp-default",
    "body": [
      "import $1 from \"${2}\";"
    ],
    "description": "Import module"
  },
  "import module destructured": {
    "prefix": "imp-destruct",
    "body": "import {$2} from \"${1:module}\""
  },
  "console.log": {
    "prefix": "clo",
    "body": "console.log(${1})"
  },
  "let statement": {
    "prefix": "let",
    "body": "let ${1:name} = ${2:value}"
  },
  "const statement": {
    "prefix": "cnt",
    "body": "const ${1:name} = ${2:value}"
  },
  "const statement from array destructuring": {
    "prefix": "cnt-destructuring-array",
    "body": "const [ ${2:prop} ] = ${1:value}"
  },
  "const statement from obj destructuring": {
    "prefix": "cnt-destructuring-obj",
    "body": "const { ${2:prop} } = ${1:value}"
  },
  "module export": {
    "prefix": "exp-cnt",
    "body": "export const ${1:var}"
  },
  "module default export": {
    "prefix": "exp-def",
    "body": "export default ${1:func}(${2:arguments}) {\n\treturn ${0}\n}"
  }
}
